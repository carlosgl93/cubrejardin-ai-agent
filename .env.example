OPENAI_API_KEY=your_openai_api_key_here

WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_TARGET_APP_ID=your_facebook_app_id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
SKIP_WEBHOOK_SIGNATURE_VALIDATION=false

WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok-free.app/webhook/whatsapp

FACEBOOK_MESSENGER_PAGE_TOKEN=your_messenger_page_token
FACEBOOK_MESSENGER_VERIFY_TOKEN=your_messenger_verify_token

DEFAULT_TEMPLATE_NAME=session_expired
TEMPLATE_MAPPING={"handoff":"handoff_notification","session_expired":"session_expired"}
MERCADO_FIEL_API_TARGET=https://southamerica-west1-mercado-fiel.cloudfunctions.net/api
MERCADO_FIEL_API_KEY=your_mercado_fiel_api_key

# Supabase
SUPABASE_URL=https://your-project.supabase.co
